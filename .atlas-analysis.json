  "keyFeatures": [
    "Programmatic wallet creation and key custody",
    "Automatic transaction signing with policy enforcement",
    "Multi-protocol support (Jupiter, Marinade, Solend, Metaplex, Orca, Raydium, Escrow)",
    "AI agent runtime with autonomous and supervised modes",
    "Comprehensive security model with multiple signer backends (encrypted-file, KMS, HSM, MPC)",
    "Durable transaction execution with RPC failover and retry logic",
    "Audit trails and execution proofs",
    "MCP-compatible tools for agent integration"
  ],
